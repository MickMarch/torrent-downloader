# qBittorrent Web UI
# Use 127.0.0.1 when running directly on the host.
# Use host.docker.internal when running inside a Docker container.
QB_HOST=127.0.0.1
QB_PORT=8080
QB_API_KEY=

# TMDB v3 API
TMDB_API_KEY=

# Search behaviour
TARGET_LANGUAGE=en
MINIMUM_SEEDERS=10
SEARCH_TIMEOUT_SECONDS=15

# Cache
CACHE_DIRECTORY=.cache
CACHE_EXPIRATION_SECONDS=3600

# API server
# Use 127.0.0.1 to bind only to localhost (host deployments).
# Use 0.0.0.0 to bind to all interfaces (required for Docker).
API_HOST=127.0.0.1
API_PORT=8000

# Media library base path
# Host-side path where qBittorrent (running on the host, not in this
# container) saves completed downloads. The app appends \Movies or \TV
# based on the request's media_type, e.g. F:\Media -> F:\Media\Movies.
# This is a host path even when torrent-downloader runs in a container,
# since save_path is sent to qBittorrent's host-side API, not used locally.
MEDIA_HOST_PATH=F:\Media
