# qBittorrent Web UI
# Use 127.0.0.1 when running directly on the host.
# Use host.docker.internal when running inside a Docker container.
QB_HOST=127.0.0.1
QB_PORT=8080
QB_API_KEY=

# TMDB v3 API
TMDB_API_KEY=

# Search behaviour
TARGET_LANGUAGE=en
MINIMUM_SEEDERS=10
SEARCH_TIMEOUT_SECONDS=15

# Cache
CACHE_DIRECTORY=.cache
CACHE_EXPIRATION_SECONDS=3600

# API server
# Use 127.0.0.1 to bind only to localhost (host deployments).
# Use 0.0.0.0 to bind to all interfaces (required for Docker).
API_HOST=127.0.0.1
API_PORT=8000

# Media-type save paths
# *_PATH: container-side path passed to qBittorrent as save_path. Mount the
# same host directories Jellyfin/medialab-jellyfin use, e.g. /media/movies.
# *_HOST_PATH: host-side equivalent of the same directory, returned to the
# orchestrator for Jellyfin library registration, e.g. F:\Media\Movies.
MOVIES_PATH=/media/movies
TV_PATH=/media/tv
MOVIES_HOST_PATH=F:\Media\Movies
TV_HOST_PATH=F:\Media\TV
