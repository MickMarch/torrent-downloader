# qBittorrent Web UI
# Use 127.0.0.1 when running directly on the host.
# Use host.docker.internal when running inside a Docker container.
QB_HOST=127.0.0.1
QB_PORT=8080
QB_API_KEY=

# TMDB v3 API
TMDB_API_KEY=

# Search behaviour
TARGET_LANGUAGE=en
MINIMUM_SEEDERS=10
SEARCH_TIMEOUT_SECONDS=15

# Cache
CACHE_DIRECTORY=.cache
CACHE_EXPIRATION_SECONDS=3600

# API server
API_HOST=127.0.0.1
API_PORT=8000
